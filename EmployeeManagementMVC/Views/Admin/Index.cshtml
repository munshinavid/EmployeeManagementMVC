@model IEnumerable<EmployeeManagementMVC.Models.Admin>
@{
    ViewData["Title"] = "Admins";
}

<div class="d-flex justify-content-between align-items-center mb-4 fade-in">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-shield-lock-fill me-2"></i>Admins
        </h2>
        <p class="text-muted mb-0">Manage administrator accounts</p>
    </div>
    <a asp-action="Create" class="btn btn-dark">
        <i class="bi bi-plus-lg me-1"></i>Add Admin
    </a>
</div>

<div class="card shadow-sm fade-in">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Username</th>
                        <th scope="col">Email</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var admin in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-muted">@admin.AdminId</td>
                            <td>
                                <i class="bi bi-person-circle me-1 text-muted"></i>@admin.Username
                            </td>
                            <td>
                                <a href="mailto:@admin.Email" class="text-decoration-none">@admin.Email</a>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@admin.AdminId" class="btn btn-outline-info btn-sm" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@admin.AdminId" class="btn btn-outline-primary btn-sm" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@admin.AdminId" class="btn btn-outline-danger btn-sm" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-shield-exclamation display-3"></i>
            <h5 class="mt-3">No Admins Found</h5>
            <p class="text-muted">Start by adding an admin account.</p>
            <a asp-action="Create" class="btn btn-dark">
                <i class="bi bi-plus-lg me-1"></i>Add Admin
            </a>
        </div>
    }
</div>
