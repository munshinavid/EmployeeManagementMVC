@model EmployeeManagementMVC.Models.Admin
@{
    ViewData["Title"] = "Admin Details";
}

<div class="row justify-content-center fade-in">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0">
                    <i class="bi bi-person-lines-fill me-2"></i>Admin Details
                </h4>
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Admin ID</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.AdminId</dd>

                    <dt class="col-sm-4 text-muted">Username</dt>
                    <dd class="col-sm-8">@Model.Username</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">
                        <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
                    </dd>
                </dl>
            </div>
            <div class="card-footer bg-white py-3">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.AdminId" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
