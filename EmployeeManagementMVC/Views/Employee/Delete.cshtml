@model EmployeeManagementMVC.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
}

<div class="row justify-content-center fade-in">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white py-3">
                <h4 class="mb-0">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion
                </h4>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    Are you sure you want to delete this employee? This action cannot be undone.
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">ID</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Id</dd>

                    <dt class="col-sm-4 text-muted">First Name</dt>
                    <dd class="col-sm-8">@Model.FirstName</dd>

                    <dt class="col-sm-4 text-muted">Last Name</dt>
                    <dd class="col-sm-8">@Model.LastName</dd>

                    <dt class="col-sm-4 text-muted">Position</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@Model.Position</span>
                    </dd>

                    <dt class="col-sm-4 text-muted">Salary</dt>
                    <dd class="col-sm-8 salary-text">@Model.Salary.ToString("C")</dd>
                </dl>
            </div>
            <div class="card-footer bg-white py-3">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
