@model IEnumerable<EmployeeManagementMVC.Models.Employee>
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4 fade-in">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-people-fill me-2"></i>Employees
        </h2>
        <p class="text-muted mb-0">Manage your employee records</p>
    </div>
    <a asp-action="Create" class="btn btn-dark">
        <i class="bi bi-plus-lg me-1"></i>Add Employee
    </a>
</div>

<div class="card shadow-sm fade-in">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">First Name</th>
                        <th scope="col">Last Name</th>
                        <th scope="col">Position</th>
                        <th scope="col">Salary</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-muted">@employee.Id</td>
                            <td>@employee.FirstName</td>
                            <td>@employee.LastName</td>
                            <td>
                                <span class="badge bg-secondary">@employee.Position</span>
                            </td>
                            <td class="salary-text">@employee.Salary.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-outline-info btn-sm" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-outline-primary btn-sm" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@employee.Id" class="btn btn-outline-danger btn-sm" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-inbox display-3"></i>
            <h5 class="mt-3">No Employees Found</h5>
            <p class="text-muted">Start by adding your first employee record.</p>
            <a asp-action="Create" class="btn btn-dark">
                <i class="bi bi-plus-lg me-1"></i>Add Employee
            </a>
        </div>
    }
</div>
